# Copy to .env and fill in the values. Variables without a value are required.

# Required
OPENROUTER_API_KEY=
FINANCEBENCH_DIR=../financebench

# Embeddings
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIM=3072
SPARSE_MODEL=Qdrant/bm25

# Vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=financerag

# Generation & evaluation
LLM_MODEL=openai/gpt-4o-mini
JUDGE_MODEL=openai/gpt-5.1

# Retrieval
RETRIEVAL_MODE=hybrid          # dense | hybrid
RERANK=true
RERANK_MODEL=cohere/rerank-4-fast
TOP_K=10
