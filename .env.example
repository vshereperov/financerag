# Copy to .env and fill in the values. Variables without a value are required.

# Connection
OPENROUTER_API_KEY=
FINANCEBENCH_DIR=../financebench
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=financerag

# Embedding
SUMMARY_MODEL=deepseek/deepseek-v4-flash
SUMMARY_REASONING_EFFORT=none  # options: none, minimal, low, medium, high, xhigh
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIM=3072
SPARSE_MODEL=Qdrant/bm25

# Retrieval
RETRIEVAL_MODE=hybrid  # options: dense, hybrid
RERANK=true
RERANK_MODEL=cohere/rerank-4-fast
CANDIDATES=30
TOP_K=10

# Generation
GENERATOR_MODEL=deepseek/deepseek-v4-flash
GENERATOR_REASONING_EFFORT=high  # options: none, minimal, low, medium, high, xhigh

# Evaluation
JUDGE_MODEL=openai/gpt-5.1
